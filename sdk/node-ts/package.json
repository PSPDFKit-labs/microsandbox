{
  "name": "microsandbox",
  "version": "0.3.14",
  "main": "index.cjs",
  "module": "index.mjs",
  "types": "index.d.cts",
  "bin": {
    "microsandbox": "bin/microsandbox.js"
  },
  "napi": {
    "binaryName": "microsandbox",
    "packageName": "@superradcompany/microsandbox",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu",
      "aarch64-unknown-linux-gnu"
    ]
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 18"
  },
  "scripts": {
    "build": "napi build --release --platform --js index.cjs --dts index.d.cts && tsc",
    "build:debug": "napi build --platform --js index.cjs --dts index.d.cts && tsc",
    "test": "vitest run",
    "postinstall": "node postinstall.js"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3",
    "@types/node": "^25.5.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1"
  },
  "files": [
    "index.cjs",
    "index.mjs",
    "index.d.cts",
    "postinstall.js",
    "bin/microsandbox.js",
    "lib/install.js",
    "dist/egress-intercept.js",
    "dist/egress-intercept.d.ts",
    "README.md"
  ]
}
